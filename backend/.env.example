# ==================== ENVIRONMENT ====================
# Pilih antara: development, production, staging
ENVIRONMENT=development

# ==================== DATABASE ====================
# Development (PostgreSQL lokal)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cloudapp

# Production (gunakan managed database)
# DATABASE_URL=postgresql://user:password@prod-host.com:5432/cloudapp_prod

# ==================== AUTHENTICATION ====================
# WAJIB: Minimal 32 karakter untuk production
SECRET_KEY=dev-secret-key-change-in-production

# Algorithm untuk JWT token (jangan diubah kecuali ada alasan khusus)
ALGORITHM=HS256

# Token expiration dalam menit
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==================== CORS ====================
# Development (multiple origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Production (hanya domain yang dipercaya)
# CORS_ORIGINS=https://app.example.com,https://www.example.com

# ==================== LOGGING ====================
# Pilih antara: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# ==================== FEATURE FLAGS ====================
# Aktifkan/nonaktifkan Swagger UI dan ReDoc
# ENABLE_DOCS=true
# ENABLE_REDOC=true
